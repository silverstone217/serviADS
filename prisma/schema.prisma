// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  role UserRole @default(USER)

  isBanned     Boolean   @default(false) @map("is_banned")
  banReason    String?   @map("ban_reason")
  banExpiresAt DateTime? @map("ban_expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]

  audioSubscribers AudioSubscriber[]

  @@map("users")
}

enum StatusAudioCampaign {
  en_cours
  terminee
  en_pause
}

model AudioCampaign {
  id String @id @default(cuid())

  name      String
  // status StatusAudioCampaign @default(en_cours)
  startDate DateTime @default(now()) @map("start_date")

  duration         Float @default(2) //week
  costPerAudio     Float @default(2) // usd dollars
  audioMaxDuration Float @default(30) // in seconds

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  audioSubscribers AudioSubscriber[]
  logs             AudioLogs[]
}

enum PaymentMethod {
  flexpaie
  cinetpay
  mpesa
  cash
  bank
}

// enum PaymentStatus {
//   en_attente_de_paiement
//   paye
//   annule
// }

model AudioSubscriber {
  id              String @id @default(cuid())
  audioCampaignId String
  subscriberId    String

  audioFile     String? //url from firebase
  audioDuration Float // in seconds

  zone       String @default("kinshasa")
  taxiNumber Int    @default(1)

  companyName String?
  clientPhone String

  price Float @default(2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  paymentRef    String? // reference du paiement
  // paymentRefRefund    String?
  paymentMethod PaymentMethod @default(flexpaie) //cinetpay, mpesa, cash, flexpaie, bank
  // paymentMethodRefund String  @default("mpesa")
  // paymentStatus       PaymentStatus  @default(paye)

  subscriber    User          @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  audioCampaign AudioCampaign @relation(fields: [audioCampaignId], references: [id], onDelete: Cascade)
}

model TaxiUser {
  id   String  @id @default(cuid())
  name String?

  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  phone    String @unique
  password String

  isBanned     Boolean   @default(false) @map("is_banned")
  banReason    String?   @map("ban_reason")
  banExpiresAt DateTime? @map("ban_expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  logs AudioLogs[]
}

model AudioLogs {
  id         String @id @default(cuid())
  campaignId String
  taxiUserId String

  avgSpeed      Float @default(0) // En km/h
  totalDuration Float @default(0) // En secondes

  date DateTime // Date du log (sans l'heure, ex: YYYY-MM-DD)

  // 🔗 Relations (Ajuste les noms "Campaign" et "User" selon tes vrais modèles)
  campaign AudioCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  taxi     TaxiUser      @relation(fields: [taxiUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 🛡️ Sécurité : Un taxi ne peut avoir qu'UN SEUL log par jour pour une même campagne
  @@unique([taxiUserId, campaignId, date])
  @@map("logs")
}
